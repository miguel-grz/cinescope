# TMDB API credentials — https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Optional overrides
# DATABASE_URL=sqlite:///./cinescope.db
# DEFAULT_REGION=CO
# CACHE_TTL_SECONDS=600

# Comma-separated list of allowed frontend origins (CORS). In production,
# set this to your deployed frontend URL, e.g.:
# CORS_ORIGINS=https://cinescope.vercel.app

# Secret used to sign session JWTs. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Cross-origin cookie flags — leave as-is for local dev. In production
# (backend and frontend on different domains), set both:
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none
